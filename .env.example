# Variabili PUBBLICHE di build (Astro). Copia in `.env` e compila.
# Su Cloudflare vanno impostate come variabili di build.

# URL canonico del sito (sitemap, hreflang, Open Graph)
SITE_URL="https://panka.app"

# Link degli store: lascia vuoto finché l'app non è pubblicata —
# i pulsanti ricadono automaticamente sul form contatti.
PUBLIC_APP_STORE_URL=""
PUBLIC_PLAY_STORE_URL=""

# Analytics (caricati solo dopo consenso dal cookie banner)
PUBLIC_GA4_ID=""            # es. G-XXXXXXXXXX
PUBLIC_META_PIXEL_ID=""     # es. 1234567890

# Cloudflare Turnstile — site key PUBBLICA (la secret va in .dev.vars)
PUBLIC_TURNSTILE_SITE_KEY=""

# Social nel footer (vuoto = icona nascosta)
PUBLIC_INSTAGRAM_URL=""
PUBLIC_FACEBOOK_URL=""
PUBLIC_TIKTOK_URL=""
