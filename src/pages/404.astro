---
import Base from '../layouts/Base.astro';
---

<Base locale="it" pagePath="/404" title="404 — Panka" description="Pagina non trovata">
  <section class="mx-auto flex max-w-xl flex-col items-center px-4 py-24 text-center sm:px-6">
    <p class="text-6xl font-extrabold text-accent-ink italic">404</p>
    <h1 class="mt-4 text-2xl font-bold">Fuorigioco! Pagina non trovata.</h1>
    <p class="mt-3 text-sm text-muted">
      Offside! Page not found. · ¡Fuera de juego! Página no encontrada.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3 text-sm font-bold">
      <a class="rounded-card bg-accent px-5 py-2.5 text-on-accent" href="/">Torna alla home</a>
      <a class="rounded-card border border-line px-5 py-2.5 text-text" href="/en/">English</a>
      <a class="rounded-card border border-line px-5 py-2.5 text-text" href="/es/">Español</a>
    </div>
  </section>
</Base>
