---
/**
 * Unico componente logo del sito. Gli SVG arrivano dal rebranding
 * (rebranding/V1, Proposta 03) già rifilati in src/assets/brand/.
 * Il wordmark è artwork: mai ricomporre "Panka" con un font simile.
 */
import wordmark from '../assets/brand/panka-wordmark.svg?raw';
import wordmarkWhite from '../assets/brand/panka-wordmark-white.svg?raw';
import wordmarkPaperAmber from '../assets/brand/panka-wordmark-paper-amber.svg?raw';
import iconGradient from '../assets/brand/panka-icon-gradient.svg?raw';
import iconFlat from '../assets/brand/panka-icon.svg?raw';

interface Props {
  /** Altezza del logo, classi Tailwind (es. 'h-8') */
  class?: string;
  /**
   * wordmark: scritta completa verde + k ambra (fondi chiari)
   * wordmark-white: scritta tutta carta (fondi scuri o fotografici)
   * wordmark-paper-amber: scritta carta + k ambra (su verde o foto, mockup PDF)
   * icon: la sola k col gradiente ambra→verde (il "marchio app")
   * icon-flat: la sola k ambra piatta (contesti piccoli)
   */
  variant?: 'wordmark' | 'wordmark-white' | 'wordmark-paper-amber' | 'icon' | 'icon-flat';
}

const { class: className = 'h-8', variant = 'wordmark' } = Astro.props;

const svgs: Record<NonNullable<Props['variant']>, string> = {
  wordmark,
  'wordmark-white': wordmarkWhite,
  'wordmark-paper-amber': wordmarkPaperAmber,
  icon: iconGradient,
  'icon-flat': iconFlat,
};
---

<span class:list={['logo block select-none', className]} set:html={svgs[variant]} />

<style>
  .logo :global(svg) {
    height: 100%;
    width: auto;
    display: block;
  }
</style>
