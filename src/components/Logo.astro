---
/**
 * Unico componente logo del sito: carica l'SVG da src/assets/brand/.
 * Per cambiare logo basta sostituire quel file (usa fill="currentColor",
 * quindi eredita il colore dal testo: bianco su fondo scuro, scuro su chiaro).
 */
import logoSvg from '../assets/brand/logo-mark.svg?raw';

interface Props {
  /** Altezza del logo, classi Tailwind (es. 'h-8') */
  class?: string;
  /** Mostra anche la scritta PANKA accanto al simbolo */
  wordmark?: boolean;
}

const { class: className = 'h-8', wordmark = false } = Astro.props;
---

<span class:list={['logo inline-flex items-center gap-2.5 select-none', className]}>
  <span class="logo-mark block h-full" set:html={logoSvg} />
  {wordmark && <span class="logo-word text-current">PANKA</span>}
</span>

<style>
  .logo-mark :global(svg) {
    height: 100%;
    width: auto;
    display: block;
  }
  .logo-word {
    font-weight: 800;
    font-style: italic;
    letter-spacing: 0.08em;
    font-size: 1em;
    line-height: 1;
  }
</style>
