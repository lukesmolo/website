---
/**
 * Confronto funzionalità per ruolo (Giocatore vs Allenatore/Admin).
 * Desktop: tabella vera. Mobile: card impilate, niente scroll orizzontale.
 */
import type { LandingContent, RoleCapability } from '../../content/types';

interface Props {
  roles: LandingContent['why']['roles'];
}

const { roles } = Astro.props;

const cellFor = (value: RoleCapability) => {
  if (value === 'yes') return { kind: 'yes' as const, label: roles.yesLabel };
  if (value === 'admin') return { kind: 'admin' as const, label: roles.adminOnlyLabel };
  return { kind: 'no' as const, label: roles.noLabel };
};
---

{/* Frammenti condivisi: spunta / trattino / chip "solo admin" */}

<div class="mt-12">
  <h3 class="text-xl font-bold">{roles.title}</h3>
  <p class="mt-2 text-sm text-muted sm:text-base">{roles.intro}</p>

  {/* --- Desktop: tabella --- */}
  <div class="mt-6 hidden overflow-hidden rounded-card border border-line-subtle md:block">
    <table class="w-full border-collapse text-left text-sm">
      <caption class="sr-only">{roles.title}</caption>
      <thead>
        <tr class="bg-surface-2 text-xs tracking-widest uppercase">
          <th scope="col" class="px-5 py-3.5 font-bold text-muted"></th>
          <th scope="col" class="w-36 px-5 py-3.5 text-center font-bold text-text">
            {roles.playerLabel}
          </th>
          <th scope="col" class="w-44 px-5 py-3.5 text-center font-bold text-text">
            {roles.staffLabel}
          </th>
        </tr>
      </thead>
      <tbody>
        {
          roles.rows.map((row) => (
            <tr class="border-t border-line-subtle bg-surface">
              <th scope="row" class="px-5 py-3.5 font-medium text-text">
                {row.feature}
              </th>
              {[cellFor(row.player), cellFor(row.staff)].map((cell) => (
                <td class="px-5 py-3.5 text-center">
                  {cell.kind === 'yes' && (
                    <span class="inline-flex items-center gap-1 font-bold text-success">
                      <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z" />
                      </svg>
                      <span class="sr-only">{cell.label}</span>
                    </span>
                  )}
                  {cell.kind === 'admin' && (
                    <span class="inline-block rounded-full bg-accent-soft px-2.5 py-1 text-[0.68rem] font-bold text-accent">
                      {cell.label}
                    </span>
                  )}
                  {cell.kind === 'no' && <span class="text-muted">{cell.label}</span>}
                </td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  {/* --- Mobile: card impilate --- */}
  <ul class="mt-6 space-y-3 md:hidden">
    {
      roles.rows.map((row) => (
        <li class="rounded-card border border-line-subtle bg-surface p-4">
          <p class="text-sm font-semibold">{row.feature}</p>
          <dl class="mt-3 grid grid-cols-2 gap-2 text-xs">
            {[
              { label: roles.playerLabel, cell: cellFor(row.player) },
              { label: roles.staffLabel, cell: cellFor(row.staff) },
            ].map(({ label, cell }) => (
              <div class="rounded-input bg-surface-2 px-3 py-2">
                <dt class="text-[0.65rem] tracking-wider text-muted uppercase">{label}</dt>
                <dd class="mt-1 font-bold">
                  {cell.kind === 'yes' && <span class="text-success">✓ {cell.label}</span>}
                  {cell.kind === 'admin' && <span class="text-accent">{cell.label}</span>}
                  {cell.kind === 'no' && <span class="text-muted">{cell.label}</span>}
                </dd>
              </div>
            ))}
          </dl>
        </li>
      ))
    }
  </ul>
</div>
