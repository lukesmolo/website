---
import type { LandingContent } from '../../content/types';
import type { UiContent } from '../../content/types';
import PhoneFrame from '../PhoneFrame.astro';
import StoreButtons from '../StoreButtons.astro';

interface Props {
  hero: LandingContent['hero'];
  store: UiContent['store'];
}

const { hero, store } = Astro.props;

/* Enfasi in ambra corsivo su una parte del titolo (stile Proposta 03).
   Se `highlight` manca o non compare nel testo, il titolo resta intero. */
const idx = hero.highlight ? hero.headline.indexOf(hero.highlight) : -1;
const before = idx >= 0 ? hero.headline.slice(0, idx) : null;
const after = idx >= 0 ? hero.headline.slice(idx + (hero.highlight?.length ?? 0)) : null;
---

<section class="relative overflow-hidden">
  <div
    class="animate-glow pointer-events-none absolute -top-32 left-1/2 h-96 w-[40rem] -translate-x-1/2 rounded-full bg-accent opacity-10 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div
    class="mx-auto grid max-w-6xl items-center gap-10 px-4 pt-14 pb-16 sm:px-6 lg:grid-cols-2 lg:gap-14 lg:pt-24 lg:pb-24"
  >
    <div class="text-center lg:text-left">
      <h1
        class="reveal text-4xl leading-tight font-extrabold tracking-tight text-primary sm:text-5xl lg:text-6xl"
      >
        {
          idx >= 0 ? (
            <>
              {before}<em class="text-accent-ink">{hero.highlight}</em>{after}
            </>
          ) : (
            hero.headline
          )
        }
      </h1>
      <p class="reveal mx-auto mt-5 max-w-md text-lg text-muted lg:mx-0 lg:text-xl" style="--reveal-delay: 120ms">
        {hero.sub}
      </p>
      <div class="reveal" style="--reveal-delay: 240ms">
        <StoreButtons store={store} location="hero" class="mt-8 justify-center lg:justify-start" />
      </div>
    </div>

    <div class="reveal relative" style="--reveal-delay: 200ms">
      {/* Anelli decorativi tipo cerchio di centrocampo, dietro al telefono */}
      <div
        class="pointer-events-none absolute top-1/2 left-1/2 h-[26rem] w-[26rem] -translate-x-1/2 -translate-y-1/2 rounded-full border border-line"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute top-1/2 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 -translate-y-1/2 rounded-full border border-line-subtle"
        aria-hidden="true"
      >
      </div>
      <div class="animate-float">
        <PhoneFrame screenshot={hero.screenshot} priority />
      </div>
    </div>
  </div>
</section>
