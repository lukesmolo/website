---
/**
 * FAQ con accordion nativi <details>/<summary>: accessibili da tastiera
 * senza JavaScript. Il JSON-LD FAQPage è generato in Seo.astro.
 */
import type { LandingContent } from '../../content/types';
import SectionTitle from '../SectionTitle.astro';

interface Props {
  faq: LandingContent['faq'];
}

const { faq } = Astro.props;
---

<section id="faq" class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:py-24">
  <SectionTitle title={faq.title} />

  <div class="mt-8 space-y-3">
    {
      faq.items.map((item) => (
        <details class="group rounded-card border border-line-subtle bg-surface">
          <summary class="flex min-h-[44px] cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-semibold [&::-webkit-details-marker]:hidden">
            {item.question}
            <svg
              class="h-5 w-5 shrink-0 text-accent transition-transform group-open:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>
          <p class="px-5 pb-5 text-sm leading-relaxed text-muted sm:text-base">{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>
