---
import type { LandingContent, UiContent } from '../../content/types';
import StoreButtons from '../StoreButtons.astro';
import Icon from '../Icon.astro';

interface Props {
  finalCta: LandingContent['finalCta'];
  store: UiContent['store'];
}

const { finalCta, store } = Astro.props;
---

{/* Banda verde di chiusura (mockup Proposta 03), glow ambra sul fondo */}
<section class="relative overflow-hidden bg-primary">
  <div
    class="animate-glow pointer-events-none absolute -bottom-24 left-1/2 h-64 w-[34rem] -translate-x-1/2 rounded-full bg-accent opacity-10 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div class="reveal relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 lg:py-24">
    <span
      class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-on-primary/10 text-accent"
    >
      <Icon name="trophy" class="h-6 w-6" />
    </span>
    <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-on-primary sm:text-4xl">{finalCta.title}</h2>
    {finalCta.sub && <p class="mt-4 text-on-primary/80">{finalCta.sub}</p>}
    <StoreButtons store={store} location="final" class="mt-8 justify-center" />
  </div>
</section>
