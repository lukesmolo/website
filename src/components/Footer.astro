---
import type { Locale } from '../content/types';
import type { SiteContent } from '../content';
import { localePath } from '../content';
import { SOCIAL_LINKS } from '../config';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
  content: SiteContent;
}

const { locale, content } = Astro.props;
const { ui } = content;
const year = new Date().getFullYear();

const socials = [
  {
    key: 'instagram',
    href: SOCIAL_LINKS.instagram,
    label: 'Instagram',
    path: 'M12 2.2c3.2 0 3.6 0 4.8.07 1.2.05 1.8.24 2.2.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.05.41 2.2.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.16-.25 1.79-.41 2.2-.22.57-.48.97-.9 1.39-.42.42-.82.68-1.38.9-.42.16-1.05.36-2.2.4-1.27.07-1.65.08-4.85.08s-3.58-.01-4.85-.07c-1.16-.05-1.79-.25-2.2-.41a3.7 3.7 0 0 1-1.39-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.05-.4-2.2C2.2 15.58 2.2 15.2 2.2 12s0-3.58.07-4.85c.05-1.16.24-1.79.41-2.2.22-.57.48-.97.9-1.39.42-.42.82-.68 1.38-.9.42-.16 1.05-.36 2.2-.4C8.42 2.2 8.8 2.2 12 2.2Zm0 1.76c-3.15 0-3.52.01-4.77.07-1.07.05-1.65.23-2.03.38-.51.2-.87.43-1.25.81-.38.38-.62.75-.81 1.25-.15.39-.33.97-.38 2.03-.06 1.25-.07 1.62-.07 4.77s.01 3.52.07 4.77c.05 1.07.23 1.65.38 2.03.2.51.43.87.81 1.25.38.38.75.62 1.25.81.39.15.97.33 2.03.38 1.25.06 1.62.07 4.77.07s3.52-.01 4.77-.07c1.07-.05 1.65-.23 2.03-.38.51-.2.87-.43 1.25-.81.38-.38.62-.75.81-1.25.15-.39.33-.97.38-2.03.06-1.25.07-1.62.07-4.77s-.01-3.52-.07-4.77c-.05-1.07-.23-1.65-.38-2.03-.2-.51-.43-.87-.81-1.25a3.36 3.36 0 0 0-1.25-.81c-.39-.15-.97-.33-2.03-.38-1.25-.06-1.62-.07-4.77-.07Zm0 3a5.03 5.03 0 1 1 0 10.07A5.03 5.03 0 0 1 12 6.97Zm0 8.3a3.27 3.27 0 1 0 0-6.53 3.27 3.27 0 0 0 0 6.53Zm6.41-8.5a1.18 1.18 0 1 1-2.35 0 1.18 1.18 0 0 1 2.35 0Z',
  },
  {
    key: 'facebook',
    href: SOCIAL_LINKS.facebook,
    label: 'Facebook',
    path: 'M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.5-3.91 3.77-3.91 1.09 0 2.23.2 2.23.2v2.46H15.2c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.45 2.9h-2.33V22c4.78-.76 8.44-4.92 8.44-9.94Z',
  },
  {
    key: 'tiktok',
    href: SOCIAL_LINKS.tiktok,
    label: 'TikTok',
    path: 'M16.6 5.82A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 1 1-2.59-2.59c.27 0 .53.04.78.12v-3.15a5.76 5.76 0 0 0-.78-.05 5.74 5.74 0 1 0 5.74 5.74V9.44a7.35 7.35 0 0 0 4.28 1.37V7.72a4.3 4.3 0 0 1-3.28-1.9Z',
  },
].filter((s) => s.href !== '');
---

<footer class="border-t border-line-subtle bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 sm:grid-cols-3">
      <div class="space-y-3">
        <Logo class="h-8" />
        <p class="text-sm text-muted">{ui.footer.tagline}</p>
        <div class="space-y-1 pt-2 text-xs leading-relaxed text-muted">
          {ui.footer.companyLines.map((line) => <p>{line}</p>)}
        </div>
      </div>

      <div>
        <h2 class="mb-3 text-xs font-bold tracking-widest text-muted uppercase">
          {ui.footer.linksHeading}
        </h2>
        <ul class="space-y-2 text-sm">
          <li>
            <a class="text-muted transition-colors hover:text-text" href={localePath(locale, '/privacy')}>
              {ui.footer.privacy}
            </a>
          </li>
          <li>
            <a class="text-muted transition-colors hover:text-text" href={localePath(locale, '/cookie-policy')}>
              {ui.footer.cookiePolicy}
            </a>
          </li>
          <li>
            <button
              type="button"
              data-cc="show-preferencesModal"
              class="cursor-pointer text-muted transition-colors hover:text-text"
            >
              {ui.footer.cookiePreferences}
            </button>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="mb-3 text-xs font-bold tracking-widest text-muted uppercase">
          {ui.footer.socialHeading}
        </h2>
        {
          socials.length > 0 ? (
            <ul class="flex gap-3">
              {socials.map((s) => (
                <li>
                  <a
                    href={s.href}
                    rel="noopener"
                    aria-label={s.label}
                    class="flex h-11 w-11 items-center justify-center rounded-card border border-line text-muted transition-colors hover:border-accent hover:text-text"
                  >
                    <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                      <path d={s.path} />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-xs text-muted">[DA COMPLETARE: link social in src/config.ts]</p>
          )
        }
      </div>
    </div>

    <p class="mt-10 border-t border-line-subtle pt-6 text-xs text-muted">
      © {year} Panka. {ui.footer.copyright}
    </p>
  </div>
</footer>
