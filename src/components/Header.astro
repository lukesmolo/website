---
import type { Locale } from '../content/types';
import type { SiteContent } from '../content';
import { localePath } from '../content';
import LangSwitcher from './LangSwitcher.astro';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
  content: SiteContent;
  pagePath: string;
  /** true sulla landing: la nav punta alle ancore della pagina */
  withNav?: boolean;
}

const { locale, content, pagePath, withNav = true } = Astro.props;
const { ui } = content;
const home = localePath(locale, '/');

const navItems = [
  { href: '#come-funziona', label: ui.nav.howItWorks },
  { href: '#perche-panka', label: ui.nav.why },
  { href: '#faq', label: ui.nav.faq },
  { href: '#contatti', label: ui.nav.contact },
];
---

<header class="sticky top-0 z-40 border-b border-line-subtle bg-primary/90 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <a href={home} class="flex items-center text-text" aria-label="Panka — home">
      <Logo class="h-8 text-accent" wordmark />
    </a>

    {
      withNav && (
        <nav class="hidden items-center gap-6 md:flex" aria-label="Menu">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm font-semibold text-muted transition-colors hover:text-text"
            >
              {item.label}
            </a>
          ))}
        </nav>
      )
    }

    <div class="flex items-center gap-3">
      <LangSwitcher current={locale} pagePath={pagePath} label={ui.langSwitcher.label} />
      {
        withNav && (
          <a
            href="#contatti"
            class="hidden rounded-card bg-accent px-4 py-2 text-sm font-bold tracking-wide text-on-accent uppercase transition-opacity hover:opacity-90 lg:inline-block"
          >
            {ui.nav.contact}
          </a>
        )
      }
    </div>
  </div>
</header>
