---
/**
 * Pulsanti di download (App Store + Google Play), elemento ricorrente.
 * Se un link store non è ancora configurato (src/config.ts), il pulsante
 * ricade sul form contatti (#contatti) invece di puntare al vuoto.
 * data-store / data-store-location alimentano il tracciamento conversioni.
 */
import { STORE_LINKS } from '../config';
import type { UiContent } from '../content/types';

interface Props {
  store: UiContent['store'];
  /** Da dove arriva il click (hero, steps, final, sticky) — per analytics */
  location: string;
  class?: string;
}

const { store, location, class: className = '' } = Astro.props;

const buttons = [
  {
    key: 'apple',
    href: STORE_LINKS.appStore,
    top: store.apple.top,
    bottom: store.apple.bottom,
  },
  {
    key: 'google',
    href: STORE_LINKS.playStore,
    top: store.google.top,
    bottom: store.google.bottom,
  },
] as const;
---

<div class:list={['flex flex-wrap items-center gap-3', className]}>
  {
    buttons.map((b) => {
      const isLive = b.href !== '';
      return (
        <a
          class="js-store-cta inline-flex min-h-14 min-w-40 items-center gap-3 rounded-card border border-line bg-surface px-4 py-2.5 text-text transition-colors hover:border-accent hover:bg-surface-2 active:bg-surface-2"
          href={isLive ? b.href : '#contatti'}
          rel={isLive ? 'noopener' : undefined}
          data-store={b.key}
          data-store-location={location}
          data-store-live={isLive ? 'true' : 'false'}
          title={isLive ? undefined : store.fallbackHint}
        >
          {b.key === 'apple' ? (
            <svg class="h-7 w-7 shrink-0 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" />
            </svg>
          ) : (
            <svg class="h-7 w-7 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#00d3fd" d="M3.6 1.8 13.7 12 3.6 22.2c-.36-.19-.6-.57-.6-1.05V2.85c0-.48.24-.86.6-1.05z" />
              <path fill="#ffd400" d="m16.85 8.85-3.15 3.15-10.1-10.2c.2-.1.44-.13.7-.05l12.55 7.1z" />
              <path fill="#ff3a44" d="M16.85 15.15 4.3 22.25c-.26.08-.5.05-.7-.05l10.1-10.2 3.15 3.15z" />
              <path fill="#00e675" d="m20.5 10.9-3.65-2.05L13.7 12l3.15 3.15 3.65-2.05c1-.57 1-1.63 0-2.2z" />
            </svg>
          )}
          <span class="flex flex-col text-left leading-tight">
            <span class="text-[0.68rem] font-medium text-muted">{b.top}</span>
            <span class="text-base font-bold">{b.bottom}</span>
          </span>
        </a>
      );
    })
  }
</div>
